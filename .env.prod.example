# .env.prod.example — committa questo file nel repo
# Copia in .env.prod e compila le variabili reali (NON committare .env.prod)

# Database
DB_NAME=gestionale_ricerca
DB_USER=gestionale_user
DB_PASSWORD=CAMBIA_QUESTA_PASSWORD

# JWT — genera una stringa casuale di almeno 64 caratteri
# Comando: openssl rand -hex 64
JWT_SECRET=STRINGA_CASUALE_LUNGA_ALMENO_64_CARATTERI
JWT_EXPIRE_MINUTES=480

# CORS — URL con cui il browser raggiunge l'applicazione
# Rete interna senza SSL:  http://192.168.1.50
# Con dominio e SSL:       https://gestionale.ateneo.it
ALLOWED_ORIGINS=http://192.168.1.50

# Storage file (lascia il default per usare il volume Docker)
UPLOAD_DIR=/app/uploads
# Se usi NAS: decommenta e imposta il path di mount sul server
# NAS_MOUNT_PATH=/mnt/nas/gestionale

# LDAP/SSO — lascia vuoto finché l'IT di ateneo non fornisce i dettagli
LDAP_URL=
LDAP_BASE_DN=
LDAP_BIND_DN=
LDAP_BIND_PASSWORD=
