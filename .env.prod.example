# .env.prod.example — committa questo file nel repo
# Copia in .env.prod e compila le variabili reali (NON committare .env.prod)

# ── Database condiviso ─────────────────────────────────────────────────────
DB_NAME=gestionale_ricerca
DB_USER=gestionale_user
DB_PASSWORD=CAMBIA_QUESTA_PASSWORD

# ── Gestionale (FastAPI) ───────────────────────────────────────────────────
# JWT — genera con: openssl rand -hex 64
JWT_SECRET=STRINGA_CASUALE_LUNGA_ALMENO_64_CARATTERI
JWT_EXPIRE_MINUTES=480

# URL con cui il browser raggiunge il gestionale (porta 80)
# Esempio IP:      http://1.2.3.4
# Esempio dominio: https://gestionale.ateneo.it
ALLOWED_ORIGINS=http://IP_DEL_SERVER

# Storage file
UPLOAD_DIR=/app/uploads

# ── Missioni-app (Django) ──────────────────────────────────────────────────
MISSIONI_DB_NAME=missioni

# genera con: python -c "import secrets; print(secrets.token_hex(50))"
DJANGO_SECRET_KEY=STRINGA_CASUALE_DJANGO

# IP o dominio del server (senza porta, virgola tra più valori)
ALLOWED_HOSTS=IP_DEL_SERVER

# URL completi da cui si accede a missioni (per CSRF)
CSRF_TRUSTED_ORIGINS=http://IP_DEL_SERVER:8001

# URL pubblico missioni (porta 8001)
MISSIONI_SITE_URL=http://IP_DEL_SERVER:8001

# URL pubblico gestionale (porta 80) — usato nella landing page missioni
GESTIONALE_FRONTEND_URL=http://IP_DEL_SERVER

# ── Integrazione gestionale ↔ missioni ────────────────────────────────────
# Chiave condivisa — genera con: openssl rand -hex 32
SYNC_API_KEY=CHIAVE_SYNC_CASUALE
